{% block extraHead %}
<style>
  .start-hero {
    padding: calc(var(--nav-h) + 64px) 0 64px;
    background: linear-gradient(160deg, #fff 0%, var(--bg-alt) 50%, #EEF2F9 100%);
    text-align: center;
  }
  .start-hero-img {
    margin-top: 32px;
  }
  .start-hero-img img {
    max-width: 240px;
    border-radius: 24px;
    box-shadow: 0 12px 48px rgba(0,0,0,.15);
    object-fit: cover;
    object-position: center 8%;
    aspect-ratio: 9 / 17;
  }

  /* Two-column step layout */
  .start-step {
    padding: 56px 0;
  }
  .start-step:nth-child(even) {
    background: var(--bg-alt);
  }
  .start-step-grid {
    display: flex;
    flex-direction: column;
    gap: 32px;
    align-items: center;
    max-width: 960px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .start-step-grid {
      flex-direction: row;
      gap: 48px;
      align-items: center;
    }
    .start-step-grid.reverse {
      flex-direction: row-reverse;
    }
    .start-step-text {
      flex: 1;
    }
    .start-step-visual {
      flex: 0 0 240px;
    }
  }

  /* Text column */
  .start-step-text h2 {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    margin-bottom: 12px;
    color: var(--text);
  }
  .start-step-text p {
    font-size: .9375rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 12px;
  }
  .start-step-text p:last-child { margin-bottom: 0; }
  .start-step-text ol {
    padding-left: 20px;
    margin-bottom: 16px;
  }
  .start-step-text ul {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 16px;
  }
  .start-step-text li {
    font-size: .9375rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }
  .start-step-text ul li {
    display: flex;
    align-items: baseline;
    gap: 10px;
    list-style: none;
  }
  .start-step-text ul li::before {
    content: '';
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal);
    margin-top: 8px;
  }
  .start-step-text ol li { margin-bottom: 6px; }
  .start-step-text strong { color: var(--text); }
  .start-step-text a {
    color: var(--teal);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition);
  }
  .start-step-text a:hover { color: var(--teal-dark); }

  /* Step number badge */
  .start-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(var(--teal-rgb), .1);
    color: var(--teal);
    font-weight: 700;
    font-size: .875rem;
    margin-bottom: 12px;
  }

  /* Screenshot column */
  .start-step-visual img {
    width: 100%;
    max-width: 240px;
    border-radius: 24px;
    box-shadow: 0 8px 40px rgba(0,0,0,.12);
    border: 1px solid var(--border);
    object-fit: cover;
    object-position: center 8%;
    aspect-ratio: 9 / 17;
  }
  /* Multi-screenshot (Step 1: 3 screens) */
  .start-step-visual-multi {
    display: flex;
    gap: 10px;
  }
  .start-step-visual-multi img {
    width: 100%;
    max-width: 150px;
    border-radius: 18px;
    box-shadow: 0 6px 24px rgba(0,0,0,.1);
    border: 1px solid var(--border);
    object-fit: cover;
    object-position: center 8%;
    aspect-ratio: 9 / 17;
  }
  @media (min-width: 768px) {
    .start-step-visual-multi {
      flex: 0 0 340px;
    }
  }

  /* Text-only step (no image) */
  .start-step-full {
    max-width: 740px;
    margin: 0 auto;
  }

  .start-summary {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 32px;
    margin-top: 16px;
  }
  .start-summary p {
    font-size: .9375rem;
    color: var(--text);
    font-weight: 500;
    line-height: 1.75;
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .start-step-visual img { max-width: 200px; }
    .start-step-visual-multi img { max-width: 120px; }
    .start-hero-img img { max-width: 200px; }
  }
</style>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Start with Payxem",
  "description": "Step-by-step guide to create your free Payxem account, send your first invoice, and start getting paid by international clients.",
  "step": [
    { "@type": "HowToStep", "name": "Create Your Free Account", "text": "Sign up at app.payxem.com using your email. No credit card needed." },
    { "@type": "HowToStep", "name": "Set Your PIN", "text": "Set a secure PIN for quick dashboard access. Enable biometric login optionally." },
    { "@type": "HowToStep", "name": "Complete Your Profile", "text": "Add your business name, service type, and location." },
    { "@type": "HowToStep", "name": "Set Up Your Payout Method", "text": "Add your bank account (IBAN) or crypto wallet (USDT) for withdrawals." },
    { "@type": "HowToStep", "name": "Verify Your Identity", "text": "Complete KYC verification to unlock withdrawals and higher limits." },
    { "@type": "HowToStep", "name": "Send Your First Invoice", "text": "Create a professional invoice with line items, set a due date, and send it to your client." },
    { "@type": "HowToStep", "name": "Track Your Earnings", "text": "View pending balance, available balance, transaction history, and invoice status from your dashboard." },
    { "@type": "HowToStep", "name": "Get Paid and Withdraw", "text": "Once balance is available, withdraw to your bank or crypto wallet." }
  ]
}
</script>
{% endblock %}

<main>
  <!-- Hero -->
  <section class="start-hero">
    <div class="container">
      <div class="section-label">Getting Started</div>
      <h1 class="headline-lg">How to Start with Payxem</h1>
      <p class="section-subtitle">From signup to your first payment in under 60 seconds. No monthly fees. No complexity.</p>
      <div class="start-hero-img">
        <img src="/images/0 start  main app-page.png" alt="Payxem app dashboard showing wallet balance, invoices, and earnings" loading="eager">
      </div>
    </div>
  </section>

  <!-- Step 1: Create Account (text left, 3 screenshots right) -->
  <section class="start-step">
    <div class="container">
      <div class="start-step-grid">
        <div class="start-step-text">
          <div class="start-num">1</div>
          <h2>Create Your Free Account</h2>
          <p>Sign up at <a href="https://app.payxem.com">app.payxem.com</a> using your email. No credit card needed. No monthly fees.</p>
          <p>You will receive a magic link to verify your email and log in securely. Open the email, tap <strong>Sign in to Payxem</strong>, and you are in.</p>
        </div>
        <div class="start-step-visual-multi">
          <img src="/images/start 1 -Payxem_Login-signup.jpg" alt="Payxem signup and login screen" loading="lazy">
          <img src="/images/start 2 magic link.jpg" alt="Payxem magic link sent confirmation" loading="lazy">
          <img src="/images/start 3 payxem email link.jpg" alt="Payxem magic link email with sign in button" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- Step 2: Set PIN (screenshot left, text right) -->
  <section class="start-step">
    <div class="container">
      <div class="start-step-grid reverse">
        <div class="start-step-text">
          <div class="start-num">2</div>
          <h2>Set Your PIN</h2>
          <p>After signing in, set a secure PIN for quick access to your dashboard. You can also enable biometric login (fingerprint or face recognition) for faster access.</p>
        </div>
        <div class="start-step-visual">
          <img src="/images/start 4 - set PIN.png" alt="Payxem set PIN screen for secure quick access" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- Step 3: Complete Profile (text left, screenshot right) -->
  <section class="start-step">
    <div class="container">
      <div class="start-step-grid">
        <div class="start-step-text">
          <div class="start-num">3</div>
          <h2>Complete Your Profile</h2>
          <p>Add your business name, service type, and location. This information appears on your invoices and helps clients trust you.</p>
        </div>
        <div class="start-step-visual">
          <img src="/images/start 5 Payxem_Profile_scr.jpg" alt="Payxem profile setup screen with business details" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- Step 4: Payout Method (text only, no screenshot) -->
  <section class="start-step">
    <div class="container">
      <div class="start-step-full">
        <div class="start-num">4</div>
        <h2>Set Up Your Payout Method</h2>
        <p>Go to your profile and add either:</p>
        <ul>
          <li><strong>Bank account</strong> (IBAN, account title, bank name) for local withdrawals</li>
          <li><strong>Crypto wallet</strong> (USDT address and chain) for fast international transfers</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Step 5: KYC (text only, no screenshot) -->
  <section class="start-step">
    <div class="container">
      <div class="start-step-full">
        <div class="start-num">5</div>
        <h2>Verify Your Identity</h2>
        <p>Complete KYC verification to unlock withdrawals and higher limits. The process takes a few minutes through our verification partner. You will need a valid government ID.</p>
      </div>
    </div>
  </section>

  <!-- Step 6: Send Invoice (screenshot left, text right) -->
  <section class="start-step">
    <div class="container">
      <div class="start-step-grid reverse">
        <div class="start-step-text">
          <div class="start-num">6</div>
          <h2>Send Your First Invoice</h2>
          <ol>
            <li>Tap <strong>Create Invoice</strong> from your dashboard</li>
            <li>Enter your client's email</li>
            <li>Add line items with description, quantity, and price</li>
            <li>Set a due date</li>
            <li>Choose whether to pass the processing fee to your client (optional)</li>
            <li>Hit <strong>Send</strong></li>
          </ol>
          <p>Your client receives a professional email with a <strong>Pay Now</strong> button. They can pay using PayPal, credit/debit card, or cryptocurrency.</p>
        </div>
        <div class="start-step-visual">
          <img src="/images/start 6 Invoice create.png" alt="Payxem invoice creation screen with line items and payment link" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- Step 7: Payment Link (text only) -->
  <section class="start-step">
    <div class="container">
      <div class="start-step-full">
        <div class="start-num">7</div>
        <h2>Or Use a Payment Link</h2>
        <p>Not every job needs a full invoice. Create a <strong>Service Link</strong> with a fixed amount and a custom URL like <strong>app.payxem.com/p/yourname</strong>. Share it anywhere. Clients click, pay, done.</p>
      </div>
    </div>
  </section>

  <!-- Step 8: Track Earnings (text left, screenshot right) -->
  <section class="start-step">
    <div class="container">
      <div class="start-step-grid">
        <div class="start-step-text">
          <div class="start-num">8</div>
          <h2>Track Your Earnings</h2>
          <p>Your dashboard shows everything in one place:</p>
          <ul>
            <li><strong>Pending balance</strong> (payments in clearance — released within 7 business days)</li>
            <li><strong>Available balance</strong> (ready to withdraw)</li>
            <li><strong>Transaction history</strong> with fee breakdowns</li>
            <li><strong>Invoice status</strong> (draft, sent, paid, completed)</li>
          </ul>
        </div>
        <div class="start-step-visual">
          <img src="/images/start 7 payxem-wallet.png" alt="Payxem wallet and ledger showing balance, transactions, and earnings" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- Step 9: Withdraw (text only) -->
  <section class="start-step">
    <div class="container">
      <div class="start-step-full">
        <div class="start-num">9</div>
        <h2>Withdraw Your Money</h2>
        <p>Once your balance is available, request a payout to your bank account or crypto wallet. Payxem does not charge any fee on withdrawals. Standard currency exchange or bank transfer fees may apply by partner or processing banks. Admin reviews and approves within 1-2 business days.</p>
      </div>
    </div>
  </section>

  <!-- Step 10: XEM (text only) -->
  <section class="start-step">
    <div class="container">
      <div class="start-step-full">
        <div class="start-num">10</div>
        <h2>Earn XEM Reward Points</h2>
        <p>You earn XEM points on every transaction, milestone, and referral. Redeem XEM for account credit to reduce your costs. The more you use Payxem, the more you save.</p>
      </div>
    </div>
  </section>

  <!-- Need Help -->
  <section class="start-step">
    <div class="container">
      <div class="start-step-full">
        <div class="start-num">?</div>
        <h2>Need Help?</h2>
        <p>Tap the chat icon to talk to <strong>XemGen</strong>, our AI assistant. It understands your account, answers questions about fees, payments, and features, and responds in your language (Urdu, Hinglish, and English).</p>
        <div class="start-summary">
          <p>Sign up (60 seconds) → Complete profile → Send invoice → Get paid → Withdraw. No monthly fees. You only pay 2.9% + $0.30 when you receive a payment. Payment processor fees vary.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <h2 class="headline-lg">Ready to Get Paid?</h2>
        <p>Create your free account, send your first invoice, and start collecting payments today.</p>
        <a href="https://app.payxem.com" class="btn btn-white btn-lg" target="_blank" rel="noopener">
          Create Free Account
          <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
        </a>
        <p class="cta-note">No credit card required. Start in under 60 seconds.</p>
      </div>
    </div>
  </section>
</main>
