<script>
'use strict';
const ALL_CUR = {
  USD: { flag: '🇺🇸', name: 'US Dollar' },
  PKR: { flag: '🇵🇰', name: 'Pakistani Rupee' },
  BDT: { flag: '🇧🇩', name: 'Bangladeshi Taka' },
  INR: { flag: '🇮🇳', name: 'Indian Rupee' },
  AED: { flag: '🇦🇪', name: 'UAE Dirham' },
  SAR: { flag: '🇸🇦', name: 'Saudi Riyal' },
  GBP: { flag: '🇬🇧', name: 'British Pound' },
  EUR: { flag: '🇪🇺', name: 'Euro' },
  CAD: { flag: '🇨🇦', name: 'Canadian Dollar' },
  AUD: { flag: '🇦🇺', name: 'Australian Dollar' },
  LKR: { flag: '🇱🇰', name: 'Sri Lankan Rupee' },
  NGN: { flag: '🇳🇬', name: 'Nigerian Naira' },
  JPY: { flag: '🇯🇵', name: 'Japanese Yen' },
  CNY: { flag: '🇨🇳', name: 'Chinese Yuan' },
  KRW: { flag: '🇰🇷', name: 'South Korean Won' },
  SGD: { flag: '🇸🇬', name: 'Singapore Dollar' },
  MYR: { flag: '🇲🇾', name: 'Malaysian Ringgit' },
  THB: { flag: '🇹🇭', name: 'Thai Baht' },
  PHP: { flag: '🇵🇭', name: 'Philippine Peso' },
  IDR: { flag: '🇮🇩', name: 'Indonesian Rupiah' },
  EGP: { flag: '🇪🇬', name: 'Egyptian Pound' },
  TRY: { flag: '🇹🇷', name: 'Turkish Lira' },
  ZAR: { flag: '🇿🇦', name: 'South African Rand' },
  BRL: { flag: '🇧🇷', name: 'Brazilian Real' },
  MXN: { flag: '🇲🇽', name: 'Mexican Peso' },
  CHF: { flag: '🇨🇭', name: 'Swiss Franc' },
  SEK: { flag: '🇸🇪', name: 'Swedish Krona' },
  NOK: { flag: '🇳🇴', name: 'Norwegian Krone' },
  NZD: { flag: '🇳🇿', name: 'New Zealand Dollar' },
  KWD: { flag: '🇰🇼', name: 'Kuwaiti Dinar' },
};

let _fxRatesUSD = {}; // rates with USD base from API
let _fxDate = '';

async function initFX() {
  try {
    const res = await fetch('https://app.payxem.com/api/exchange-rates');
    const data = await res.json();
    _fxRatesUSD = data.rates || {};
    _fxDate = data.date || '';
    renderConverter();
    renderGrid();
  } catch {
    document.getElementById('fx-card').innerHTML = '<p style="text-align:center;color:#EF4444;padding:20px">Unable to load exchange rates. Please try again later.</p>';
  }
}

function getCurOptions(selected) {
  return Object.entries(ALL_CUR).map(([code, c]) =>
    `<option value="${code}" ${code === selected ? 'selected' : ''}>${c.flag} ${code} — ${c.name}</option>`
  ).join('');
}

function renderConverter() {
  const defaultTo = detectCurrency();
  document.getElementById('fx-card').innerHTML = `
    <div class="fx-input-row">
      <div class="fx-input-group">
        <label>Amount</label>
        <input type="number" id="fx-amount" value="100" min="0" step="1" oninput="updateFX()">
      </div>
      <div class="fx-input-group">
        <label>From</label>
        <select id="fx-from" onchange="updateFX();renderGrid()">${getCurOptions('USD')}</select>
      </div>
      <button class="fx-swap" onclick="swapCurrencies()" title="Swap currencies">⇄</button>
      <div class="fx-input-group">
        <label>To</label>
        <select id="fx-to" onchange="updateFX()">${getCurOptions(defaultTo)}</select>
      </div>
    </div>
    <div class="fx-result" id="fx-result"></div>
    <div class="fx-updated" id="fx-updated"></div>
  `;
  updateFX();
}

function getRate(from, to) {
  if (from === to) return 1;
  if (from === 'USD') return _fxRatesUSD[to] || 0;
  if (to === 'USD') return _fxRatesUSD[from] ? 1 / _fxRatesUSD[from] : 0;
  // Cross rate: FROM→USD→TO
  const fromUSD = _fxRatesUSD[from];
  const toUSD = _fxRatesUSD[to];
  if (!fromUSD || !toUSD) return 0;
  return toUSD / fromUSD;
}

function fmt(n) {
  if (n >= 1000) return Number(n.toFixed(2)).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
  if (n >= 1) return n.toFixed(4);
  return n.toFixed(6);
}

function updateFX() {
  const amt = Math.max(0, Number(document.getElementById('fx-amount')?.value) || 0);
  const from = document.getElementById('fx-from')?.value || 'USD';
  const to = document.getElementById('fx-to')?.value || 'PKR';
  const rate = getRate(from, to);
  const el = document.getElementById('fx-result');
  const upd = document.getElementById('fx-updated');
  if (!rate) { el.innerHTML = '<p style="color:var(--text-muted)">Rate unavailable</p>'; return; }
  const converted = amt * rate;
  const toInfo = ALL_CUR[to] || {};
  const fromInfo = ALL_CUR[from] || {};
  el.innerHTML = `
    <div class="fx-result-amount">${toInfo.flag || ''} ${fmt(converted)}</div>
    <div class="fx-result-label">${amt.toLocaleString()} ${from} = ${fmt(converted)} ${to}</div>
    <div class="fx-result-rate">1 ${from} = ${fmt(rate)} ${to}</div>
  `;
  const now = new Date();
  const time = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');
  upd.textContent = _fxDate ? _fxDate + ' · ' + time + ' · Updates hourly' : '';
}

function swapCurrencies() {
  const fromEl = document.getElementById('fx-from');
  const toEl = document.getElementById('fx-to');
  const temp = fromEl.value;
  fromEl.value = toEl.value;
  toEl.value = temp;
  updateFX();
  renderGrid();
}

function renderGrid() {
  const base = document.getElementById('fx-from')?.value || 'USD';
  const grid = document.getElementById('fx-grid');
  const title = document.getElementById('fx-grid-title');
  const baseInfo = ALL_CUR[base] || {};
  title.textContent = `All rates vs ${baseInfo.flag || ''} ${base}`;

  grid.innerHTML = Object.entries(ALL_CUR).filter(([code]) => code !== base).map(([code, c]) => {
    const rate = getRate(base, code);
    if (!rate) return '';
    return `<div class="fx-tile" onclick="document.getElementById('fx-to').value='${code}';updateFX();window.scrollTo({top:0,behavior:'smooth'})">
      <div class="fx-tile-flag">${c.flag}</div>
      <div class="fx-tile-code">${code}</div>
      <div class="fx-tile-rate">${fmt(rate)}</div>
      <div class="fx-tile-name">${c.name}</div>
    </div>`;
  }).join('');
}

function detectCurrency() {
  try {
    const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
    if (tz.includes('Karachi')) return 'PKR';
    if (tz.includes('Dhaka')) return 'BDT';
    if (tz.includes('Kolkata') || tz.includes('Calcutta')) return 'INR';
    if (tz.includes('Dubai')) return 'AED';
    if (tz.includes('Riyadh')) return 'SAR';
    if (tz.includes('London')) return 'GBP';
    if (tz.includes('Lagos')) return 'NGN';
    if (tz.includes('Colombo')) return 'LKR';
    if (tz.includes('Sydney') || tz.includes('Melbourne')) return 'AUD';
    if (tz.includes('Toronto') || tz.includes('Vancouver')) return 'CAD';
    if (tz.includes('Paris') || tz.includes('Berlin') || tz.includes('Rome')) return 'EUR';
    if (tz.includes('Tokyo')) return 'JPY';
    if (tz.includes('Seoul')) return 'KRW';
    if (tz.includes('Singapore')) return 'SGD';
    if (tz.includes('Bangkok')) return 'THB';
    if (tz.includes('Manila')) return 'PHP';
    if (tz.includes('Jakarta')) return 'IDR';
    if (tz.includes('Istanbul')) return 'TRY';
    if (tz.includes('Zurich')) return 'CHF';
    if (tz.includes('Stockholm')) return 'SEK';
  } catch {}
  return 'PKR';
}

initFX();
</script>
