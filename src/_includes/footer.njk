<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="nav-logo" aria-label="Payxem Home">
          <img src="/images/Payxem-main-logo.png" alt="Payxem - freelancer invoicing and payment platform" width="120" height="30" style="filter: brightness(0) invert(1);">
        </a>
        <p>Professional Invoicing & Payments for individual freelancers and Businesses.</p>
      </div>
      <div class="footer-divider-v"></div>
      <div class="footer-col footer-col-reads">
        <div class="footer-reads-list">
          <div class="footer-reads-col">
            {% for post in collections.blog | limit(2) %}
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            {% endfor %}
          </div>
          <h4>Worth Reading</h4>
          <div class="footer-reads-col">
            {% set allPosts = collections.blog %}
            {% for post in allPosts %}
            {% if loop.index > 2 and loop.index <= 4 %}
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    <div class="footer-links-row">
      <div class="footer-links-group">
        <span>Important Links:</span>
        <a href="/features">Features</a><span class="footer-sep">|</span>
        <a href="{% if isHome %}#pricing{% else %}/#pricing{% endif %}">Pricing</a><span class="footer-sep">|</span>
        <a href="{% if isHome %}#how-it-works{% else %}/#how-it-works{% endif %}">How It Works</a><span class="footer-sep">|</span>
        <a href="{% if isHome %}#faq{% else %}/#faq{% endif %}">FAQ</a><span class="footer-sep">|</span>
        <a href="/about">About</a><span class="footer-sep">|</span>
        <a href="/blog/">Blog</a><span class="footer-sep">|</span>
        <a href="/waitlist/">Join Waitlist</a><span class="footer-sep">|</span>
        <a href="/how-to-start/">Get Started</a><span class="footer-sep">|</span>
        <a href="/currency-converter/">Currency Converter</a>
        <span class="footer-sep">&nbsp;&nbsp;</span>
        <span>Legal:</span>
        <a href="/terms">Terms of Service</a><span class="footer-sep">|</span>
        <a href="/privacy">Privacy Policy</a>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <p class="footer-disclaimer"><span class="footer-label">Disclaimer:</span> Payxem is an invoicing and payment platform that enables users to send invoices and payment links, and receive payments through trusted third-party providers such as PayPal and Stripe. Payxem is not a bank, financial institution, or payment processor, and does not provide custody or money transmission services. <span class="footer-copyright">&copy; {{ site.copyrightYear }} Payxem. All rights reserved.</span></p>
      </div>
    </div>
  </div>
</footer>
