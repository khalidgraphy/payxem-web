<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="nav-logo" aria-label="Payxem Home">
          <img src="/images/Payxem-main-logo.png" alt="Payxem - freelancer invoicing and payment platform" width="120" height="30" style="filter: brightness(0) invert(1);">
        </a>
        <p>The platform for Digitalancers. Payments, portfolio, and presence at one link.</p>
        <p style="font-size:.6rem;color:rgba(255,255,255,.3);margin-top:8px"><strong style="color:rgba(255,255,255,.45)">Powered by LINC GLOBAL HUB INC.</strong><br>Delaware Corporation (Regd)<br>Dover, DE, United States</p>
      </div>
      <div class="footer-divider-v"></div>
      <div class="footer-col footer-col-reads">
        <h4>Worth Reading</h4>
        <div class="footer-reads-list">
          {#
            10 latest blog posts across two columns, 5 per column.
            Left column holds positions 1-3 + alternating fills at 4 + 5 (posts 7 and 9).
            Right column holds positions 4-6 + alternating fills at 4 + 5 (posts 8 and 10).
            Matches the user's described fill order: 1 2 3 go left, 4 5 6 go right,
            then 7 left, 8 right, 9 left, 10 right.
          #}
          <div class="footer-reads-col">
            {% set leftIdx = [1, 2, 3, 7, 9] %}
            {% for post in collections.blog %}
            {% if loop.index in leftIdx %}
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            {% endif %}
            {% endfor %}
          </div>
          <div class="footer-reads-col">
            {% set rightIdx = [4, 5, 6, 8, 10] %}
            {% for post in collections.blog %}
            {% if loop.index in rightIdx %}
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    <div class="footer-links-row">
      <div class="footer-links-group">
        <span>Important Links:</span>
        <a href="https://app.payxem.com" target="_blank" rel="noopener">Start Free</a><span class="footer-sep">|</span>
        <a href="/how-to-start/">Get Started</a><span class="footer-sep">|</span>
        <a href="{% if isHome %}#how-it-works{% else %}/#how-it-works{% endif %}">How It Works</a><span class="footer-sep">|</span>
        <a href="/about">About</a><span class="footer-sep">|</span>
        <a href="/features">Features</a><span class="footer-sep">|</span>
        <a href="https://pxem.link" target="_blank" rel="noopener">Digital Business Card</a><span class="footer-sep">|</span>
        <a href="{% if isHome %}#pricing{% else %}/#pricing{% endif %}">Pricing</a><span class="footer-sep">|</span>
        <a href="{% if isHome %}#faq{% else %}/#faq{% endif %}">FAQ</a><span class="footer-sep">|</span>
        <a href="/currency-converter/">FX Rates</a><span class="footer-sep">|</span>
        <a href="/user-manual/">User Manual</a><span class="footer-sep">|</span>
        <a href="/blog/">Blog</a>
      </div>
      <div class="footer-links-group" style="margin-top:6px">
        <span>Legal:</span>
        <a href="/terms/">Terms of Service</a><span class="footer-sep">|</span>
        <a href="/privacy/">Privacy Policy</a><span class="footer-sep">|</span>
        <a href="/disputes-and-refunds/">Disputes & Refunds</a><span class="footer-sep">|</span>
        <a href="/acceptable-use/">Acceptable Use</a><span class="footer-sep">|</span>
        <a href="/cookies/">Cookie Policy</a>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <p class="footer-disclaimer"><span class="footer-label">Disclaimer:</span> Payxem is an invoicing and link payment coordination platform. Payments are processed by regulated trusted third-party providers.<br>Payxem is not a bank, financial institution, or payment processor, and does not hold or custody funds.</p>
        <p style="font-size:.625rem;color:rgba(255,255,255,.4);margin-top:6px;text-align:center"><span class="footer-copyright">&copy; {{ site.copyrightYear }} Payxem. All rights reserved.</span></p>
      </div>
    </div>
  </div>
</footer>
