  .m-pl-amt { font-size: 1.1rem; font-weight: 800; color: var(--navy); margin-top: 4px; }
  .m-pl-svc { font-size: 0.5rem; font-weight: 600; margin-top: 3px; }
  .m-pl-d { font-size: 0.4rem; color: #9CA3AF; }

