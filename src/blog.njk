---
layout: base.njk
title: "Blog | Payxem — Invoicing Tips for Freelancers"
description: "Tips, guides, and updates for freelancers who want to get paid faster. Learn about invoicing, payments, and running your business."
permalink: /blog/
isHome: false
extraCss: /css/blog.css
---

{% block content %}
<main>
  <section class="blog-hero">
    <div class="container">
      <div class="section-label">Blog</div>
      <h1 class="headline-lg">Insights for Freelancers</h1>
      <p class="section-subtitle">Tips, guides, and platform updates to help you invoice smarter and get paid faster.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {% if collections.blog.length %}
      <div class="blog-grid">
        {% for post in collections.blog %}
        <article class="blog-card reveal{% if loop.index > 1 %} reveal-delay-{{ (loop.index0 % 3) }}{% endif %}">
          {% if post.data.featuredImage %}
          <a href="{{ post.url }}" class="blog-card-image">
            <img src="{{ post.data.featuredImage }}" alt="{{ post.data.featuredImageAlt or post.data.title }}" loading="lazy">
          </a>
          {% endif %}
          <div class="blog-card-body">
            {% if post.data.category %}<span class="blog-card-category">{{ post.data.category }}</span>{% endif %}
            <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
            <p>{{ post.data.description }}</p>
            <div class="blog-card-meta">
              <time datetime="{{ post.date | isoDate }}">{{ post.date | dateFormat }}</time>
              {% if post.data.readTime %}<span>&middot;</span><span>{{ post.data.readTime }} min read</span>{% endif %}
            </div>
          </div>
        </article>
        {% endfor %}
      </div>
      {% else %}
      <div style="text-align: center; padding: 80px 0;">
        <p class="text-lg text-muted">No posts yet. Check back soon.</p>
      </div>
      {% endif %}
    </div>
  </section>
</main>
{% endblock %}
