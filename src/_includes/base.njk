<!DOCTYPE html>
<html lang="en"{% if isHome %} class="no-js"{% endif %}>
<head>
  {% if isHome %}<script>document.documentElement.classList.remove('no-js')</script>{% endif %}
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#1A3060">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cloud.umami.is; connect-src 'self' https://cloud.umami.is https://app.payxem.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; frame-ancestors 'none'">
  <meta name="description" content="{{ description or site.description }}">
  {% if keywords %}<meta name="keywords" content="{{ keywords }}">{% endif %}
  <meta name="robots" content="{{ robots or 'index, follow' }}">
  {% if author %}<meta name="author" content="{{ author }}">{% endif %}

  <meta property="og:title" content="{{ ogTitle or title }}">
  <meta property="og:description" content="{{ ogDescription or description or site.description }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ ogImage or site.url + '/images/PayXem-Icon.png' }}">
  <meta property="og:site_name" content="Payxem">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ ogTitle or title }}">
  <meta name="twitter:description" content="{{ ogDescription or description or site.description }}">
  <meta name="twitter:image" content="{{ ogImage or site.url + '/images/PayXem-Icon.png' }}">

  <link rel="canonical" href="{{ site.url }}{{ page.url | replace('/index.html', '') }}">
  <link rel="icon" type="image/png" href="/images/PayXem-Icon.png">
  <link rel="apple-touch-icon" href="/images/PayXem-Icon.png">
  <link rel="alternate" type="application/rss+xml" title="{{ site.name }} Blog" href="{{ site.url }}/feed.xml">
  <title>{{ title }}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=20260413d">
  {% if extraCss %}<link rel="stylesheet" href="{{ extraCss }}?v=20260411">{% endif %}

  {% block extraHead %}{% endblock %}
  {% block structuredData %}{% endblock %}

  <script defer src="https://cloud.umami.is/script.js" data-website-id="{{ site.umamiId }}"></script>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-NHNKYT3PEN"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-NHNKYT3PEN');
  </script>
</head>
<body>

  {% include "nav.njk" %}

  {% block content %}{{ content | safe }}{% endblock %}

  {% include "footer.njk" %}

  <!-- Floating QR Card -->
  <style>
    @keyframes qr-float-bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
    @keyframes qr-pulse { 0%,100% { box-shadow: 0 8px 32px rgba(26,48,96,.12), 0 0 0 0 rgba(26,48,96,.15); } 50% { box-shadow: 0 8px 32px rgba(26,48,96,.12), 0 0 0 6px rgba(26,48,96,.06); } }
    @keyframes qr-slide-in { from { opacity:0; transform: translateY(40px); } to { opacity:1; transform: translateY(0); } }
    #qr-float {
      position:fixed; bottom:20px; right:20px; z-index:900; background:#fff; border-radius:16px;
      padding:14px 16px; text-decoration:none; display:flex; align-items:center; gap:12px; max-width:280px;
      border:1.5px solid #E5E7EB; cursor:pointer;
      animation: qr-slide-in .5s ease-out, qr-float-bob 3s ease-in-out 1s infinite, qr-pulse 3s ease-in-out 1s infinite;
      transition: transform .25s ease, box-shadow .25s ease;
    }
    #qr-float:hover {
      transform: scale(1.08) translateY(-4px) !important;
      box-shadow: 0 16px 48px rgba(26,48,96,.2), 0 0 0 4px rgba(26,48,96,.08) !important;
      animation: none;
    }
    @media (max-width: 500px) { #qr-float { bottom:12px; right:12px; max-width:250px; padding:10px 12px; gap:10px; } }
  </style>
  <a href="https://app.payxem.com" id="qr-float" target="_blank" rel="noopener">
    <div style="flex-shrink:0">
      <img src="/images/PayXem-QR-join.png" alt="Scan to open Payxem app" width="72" height="72" style="border-radius:8px;display:block" loading="lazy">
    </div>
    <div>
      <div style="font-size:.78rem;font-weight:800;color:#1A3060;line-height:1.3">Start on Payxem</div>
      <div style="font-size:.65rem;color:#6B7280;line-height:1.4;margin-top:3px">Payments, Portfolio, Presence.<br>Scan or tap to open the app.</div>
    </div>
    <button onclick="event.preventDefault();event.stopPropagation();document.getElementById('qr-float').style.display='none'" style="position:absolute;top:6px;right:8px;background:none;border:none;font-size:.85rem;color:#9CA3AF;cursor:pointer;padding:2px;line-height:1" aria-label="Close">&times;</button>
  </a>

  <script src="/js/main.js"></script>
</body>
</html>
