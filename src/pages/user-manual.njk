  .m-hl-l { position: absolute; left: 50%; bottom: -13px; transform: translateX(-50%); background: #F59E0B; color: #fff; padding: 2px 5px; border-radius: 3px; font-size: 0.38rem; font-weight: 700; white-space: nowrap; z-index: 5; }
  .m-hl-l::before { content: ''; position: absolute; left: 50%; top: -3px; transform: translateX(-50%); border: 3px solid transparent; border-bottom-color: #F59E0B; }

  /* XEM card */
  .m-mx { background: linear-gradient(135deg, #1A3060, #2BC4C0); color: #fff; border-radius: 7px; padding: 7px; margin: 0 8px 5px; display: flex; justify-content: space-between; align-items: center; }
  .m-mx-l { font-size: 0.4rem; opacity: 0.8; text-transform: uppercase; }
  .m-mx-v { font-size: 0.8rem; font-weight: 800; }
  .m-mx-s { font-size: 0.4rem; opacity: 0.6; }
  .m-mx-b { padding: 3px 6px; border-radius: 4px; font-size: 0.4rem; font-weight: 700; background: rgba(255,255,255,0.2); color: #fff; }

