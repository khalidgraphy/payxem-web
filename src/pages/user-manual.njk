  .m-pbtn { width: 100%; padding: 7px; background: var(--navy); color: #fff; border: none; border-radius: 4px; font-size: 0.55rem; font-weight: 700; margin-top: 4px; text-align: center; }
  .m-pf { text-align: center; padding: 5px; font-size: 0.35rem; color: #9CA3AF; }

