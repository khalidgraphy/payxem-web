  .m-tbl tr:nth-child(even) td { background: #F9FAFB; }

  /* Page divider */
  .m-divider { border: none; border-top: 2px solid #E5E7EB; margin: 40px 0 0; }

  /* Help box */
  .m-help { margin-top: 24px; padding: 20px 24px; background: #F0F9FF; border-radius: 12px; border-left: 4px solid var(--teal); }
