---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.name }} Blog</title>
    <link>{{ site.url }}/blog/</link>
    <description>Tips, guides, and updates for freelancers who want to get paid faster. Learn about invoicing, payments, and running your business.</description>
    <language>en</language>
    <atom:link href="{{ site.url }}/feed.xml" rel="self" type="application/rss+xml"/>
    {%- for post in collections.blog | reverse %}
    <item>
      <title>{{ post.data.title }}</title>
      <link>{{ site.url }}{{ post.url }}</link>
      <guid isPermaLink="true">{{ site.url }}{{ post.url }}</guid>
      <pubDate>{{ post.date | isoDate }}</pubDate>
      <description>{{ post.data.description }}</description>
      {%- if post.data.featuredImage %}
      {%- if post.data.featuredImage.startsWith('http') %}
      <enclosure url="{{ post.data.featuredImage }}" type="image/jpeg"/>
      {%- else %}
      <enclosure url="{{ site.url }}{{ post.data.featuredImage }}" type="image/jpeg"/>
      {%- endif %}
      {%- endif %}
    </item>
    {%- endfor %}
  </channel>
</rss>
